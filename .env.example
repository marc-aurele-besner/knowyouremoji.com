# KnowYourEmoji Environment Configuration
# Copy this file to .env.local and fill in the values

# =============================================================================
# App Configuration
# =============================================================================

# Public URL of the application
# Default: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application name displayed in UI and metadata
# Default: KnowYourEmoji
NEXT_PUBLIC_APP_NAME=KnowYourEmoji

# =============================================================================
# OpenRouter Configuration (Required for Interpreter)
# =============================================================================

# OpenRouter API key for the emoji interpreter feature
# Get your key at: https://openrouter.ai/keys
# Required if NEXT_PUBLIC_ENABLE_INTERPRETER is true
OPENROUTER_API_KEY=sk-or-your-key-here

# OpenRouter model to use for interpretations
# Default: liquid/lfm2-8b-a1b
OPENROUTER_MODEL=liquid/lfm2-8b-a1b

# =============================================================================
# Feature Flags
# =============================================================================

# Enable the AI interpreter tool
# Set to "false" to disable the interpreter feature
# Default: true
NEXT_PUBLIC_ENABLE_INTERPRETER=true

# =============================================================================
# Analytics & Monitoring (Optional for local dev)
# =============================================================================

# Google Analytics 4 Measurement ID
# Get your measurement ID at: https://analytics.google.com
# Format: G-XXXXXXXXXX
# Leave empty for local development
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# PostHog Product Analytics API key
# Get your key at: https://app.posthog.com/project/settings
# Format: phc_XXXXXXXXXX
# Leave empty for local development
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog API Host URL
# Default: https://us.i.posthog.com (US cloud)
# Use https://eu.i.posthog.com for EU cloud
# Leave empty to use default
NEXT_PUBLIC_POSTHOG_HOST=

# Sentry DSN for error monitoring (server-side)
# Get your DSN at: https://sentry.io
# Leave empty for local development
SENTRY_DSN=

# Sentry DSN for error monitoring (client-side)
# This should be the same as SENTRY_DSN but with NEXT_PUBLIC prefix
# Leave empty for local development
NEXT_PUBLIC_SENTRY_DSN=

# Sentry organization slug (for source map uploads)
# Leave empty for local development
SENTRY_ORG=

# Sentry project slug (for source map uploads)
# Leave empty for local development
SENTRY_PROJECT=

# =============================================================================
# Neon Postgres (Required for auth and features)
# =============================================================================

# Connection string from Neon (Dashboard → Connection details).
# Used for auth tables (users, accounts, sessions), interpretation history,
# and emoji detail page view counts.
DATABASE_URL=

# =============================================================================
# Authentication (NextAuth)
# =============================================================================

# NextAuth secret for JWT signing (generate with: openssl rand -base64 32)
AUTH_SECRET=

# NextAuth URL (same as NEXT_PUBLIC_APP_URL)
AUTH_URL=http://localhost:3000

# Google OAuth (optional — enable "Continue with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional — enable "Continue with GitHub")
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# =============================================================================
# Resend (Email service for verification and password reset)
# =============================================================================

# Resend API key (get at https://resend.com)
RESEND_API_KEY=

# Sender email address (must be verified in Resend)
RESEND_FROM_EMAIL=noreply@knowyouremoji.com

# =============================================================================
# Slack Logging (Optional)
# =============================================================================

# Slack Bot token for logging interpreter usage to a channel
# Create a Slack app and install it to your workspace
# Required scopes: chat:write
# Leave empty to disable Slack logging
SLACK_BOT_TOKEN=

# Slack channel ID where interpreter usage logs are posted
# Right-click a channel in Slack → "View channel details" → copy the Channel ID
# Leave empty to disable Slack logging
SLACK_LOG_CHANNEL_ID=

# =============================================================================
# Stripe (Payments & Subscriptions)
# =============================================================================

# Stripe secret key (server-side, starts with sk_)
# Get your key at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Stripe publishable key (client-side, starts with pk_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe webhook secret for verifying webhook signatures (starts with whsec_)
STRIPE_WEBHOOK_SECRET=

# Stripe price ID for the Pro subscription plan (starts with price_)
STRIPE_PRO_PRICE_ID=
